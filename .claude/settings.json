{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ensure-mcp-server-built.cjs",
            "timeout": 180,
            "statusMessage": "Building product-agent MCP server for new worktree"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ensure-mcp-server-built.cjs",
            "timeout": 180,
            "statusMessage": "Ensuring product-agent MCP server is built"
          }
        ]
      }
    ]
  }
}
